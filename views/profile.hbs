<div class="container mt-5">
    <div class="row">
        <div class="col-md-4">
            <div class="card text-center p-3 shadow-sm">
                <img src="{{profileUser.photoUrl}}" class="rounded-circle mx-auto d-block mb-2" 
                    width="100" height="100" style="object-fit:cover;" alt="Profile Picture">
                <h4 class="mt-2">{{capital profileUser.name}}</h4>
                <p class="text-muted mb-1">{{profileUser.email}}</p>
                <span class="badge bg-secondary text-uppercase mb-2">{{profileUser.role}}</span>
                <hr>
                <div class="text-start">
                    <label class="fw-bold">Bio:</label>
                    <p id="bioText">{{profileUser.bio}}</p>
                </div>
                
                {{#if isSelf}}
                <div id="selfTools" class="d-grid gap-2">
                    <button onclick="editMyBio()" class="btn btn-sm btn-outline-secondary">Edit Bio</button>
                    <button onclick="editPhoto()" class="btn btn-sm btn-outline-primary">Edit Photo</button>
                    <button onclick="deleteAccount()" class="btn btn-sm btn-danger">Delete Account</button>
                </div>
                {{/if}}
            </div>
        </div>

        <div class="col-md-8">
            <h3>Lab Reservations</h3>
            <table class="table table-striped table-bordered mt-3 bg-white shadow-sm">
                <thead class="table-dark">
                    <tr>
                        <th>Room</th>
                        <th>Time Slot</th>
                        <th>Date</th>
                        {{#if isSelf}}<th>Action</th>{{/if}}
                    </tr>
                </thead>
                <tbody>
                    {{#each reservations}}
                    <tr>
                        <td>{{this.room}}</td>
                        <td>{{this.slotTime}}</td>
                        <td>{{formatDate this.date}}</td>
                        {{#if ../isSelf}}
                        <td>
                            {{! FIXED: wired to POST /cancel-reservation via a proper form }}
                            <form action="/cancel-reservation" method="POST" class="m-0">
                                <input type="hidden" name="resId" value="{{this._id}}">
                                <button type="submit" class="btn btn-sm btn-outline-danger"
                                    onclick="return confirm('Cancel this reservation?')">
                                    Cancel
                                </button>
                            </form>
                        </td>
                        {{/if}}
                    </tr>
                    {{else}}
                    <tr>
                        <td colspan="{{#if isSelf}}4{{else}}3{{/if}}" class="text-center text-muted">
                            No reservations found.
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>
</div>

{{#section "pageScripts"}}
    <script src="/js/profile.js"></script>
{{/section}}

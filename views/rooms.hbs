{{#section "pageStyles"}}
<style>
    .table-responsive { max-height: 70vh; overflow-y: auto; }
    .btn-available { background-color: #ffffff; color: #2e8b57; border: 1px solid #2e8b57; }
    .btn-selected { background-color: #ffc107 !important; color: #000 !important; border: 1px solid #ffc107; } 
    .btn-reserved { background-color: #842029 !important; color: white !important; cursor: pointer; } 
    .btn-faculty { background-color: #0d6efd !important; color: white !important; } 
    .btn-checkedin { background-color: #198754 !important; color: white !important; border: 1px solid #198754; }
</style>
{{/section}}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
    <h2 id="roomTitle">{{labName}}</h2>
    <div class="d-flex gap-2">
        <button id="confirmBtn" class="btn btn-success" style="display:none;" onclick="showPrivacyModal()">
            Confirm Reservation
        </button>
        <a href="/search" class="btn btn-outline-secondary">Back</a>
    </div>
    </div>

    <div class="table-responsive bg-white shadow-sm rounded">
        <table class="table table-bordered text-center align-middle mb-0">
            <thead class="table-dark sticky-top">
                <tr>
                    <th>Timeslots</th>
                    {{#each days}}<th>{{this}}</th>{{/each}}
                </tr>
            </thead>
            <tbody>
                {{#each timeslots}}
                <tr>
                    <td class="fw-bold small">{{this.timeLabel}}</td>
                    {{#each this.dayCells}}
                    <td>
                        {{#if this.reserved}}
                            {{#if this.isCheckedIn}}
                                <button class="btn btn-sm btn-checkedin w-100" disabled>CHECKED-IN</button>
                            {{else if this.isFaculty}}
                                <button class="btn btn-sm btn-faculty w-100" disabled>FACULTY</button>
                            {{else}}
                                <button class="btn btn-sm btn-reserved w-100" disabled>Reserved</button>
                            {{/if}}
                        {{else}}
                            <button class="btn btn-sm btn-available w-100" onclick="reserveSlot(this, 
                            '{{../timeLabel}}', '{{this.date}}', '{{../../labName}}', 
                            {{this.slotIndex}})">Reserve
                            </button>
                        {{/if}}
                    </td>
                    {{/each}}
                </tr>
                {{/each}}
            </tbody>
        </table>
    </div>

    <div class="mt-3 d-flex justify-content-center gap-3">
        <span><span class="badge btn-available border text-dark">White</span> Available</span>
        <span><span class="badge bg-warning text-dark">Yellow</span> Selected</span>
        <span><span class="badge bg-danger">Red</span> Reserved</span>
        <span><span class="badge bg-primary">Blue</span> Faculty</span>
        <span><span class="badge bg-success">Green</span> Checked-in</span>
    </div>
</div>

{{#section "pageScripts"}}
<script src="/js/rooms.js"></script>
{{/section}}

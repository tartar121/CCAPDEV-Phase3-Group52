{{#section "pageStyles"}}
<style>
    .table-responsive { max-height: 70vh; overflow-y: auto; }
    .btn-available  { background-color: #ffffff; color: #2e8b57; border: 1px solid #2e8b57; }
    .btn-selected   { background-color: #ffc107 !important; color: #000 !important; border: 1px solid #ffc107; } 
    .btn-reserved   { background-color: #842029 !important; color: white !important; cursor: pointer; } 
    .btn-faculty    { background-color: #0d6efd !important; color: white !important; } 
    .btn-checkedin  { background-color: #198754 !important; color: white !important; border: 1px solid #198754; }
    .btn-walkin     { background-color: #6f42c1 !important; color: white !important; cursor: default; }
    .tech-panel     { background: #fff3cd; border: 1px solid #ffc107; border-radius: 8px; padding: 12px 16px; margin-bottom: 16px; }
</style>
{{/section}}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 id="roomTitle">{{labName}}</h2>
        <div class="d-flex gap-2">
            <button id="confirmBtn" class="btn btn-success" style="display:none;" onclick="showPrivacyModal()">
                Confirm Reservation
            </button>
            {{! FIXED: back button goes to dashboard, not /search }}
            <a href="/" class="btn btn-outline-secondary">← Dashboard</a>
        </div>
    </div>

    {{! Technician panel — only visible to technicians }}
    {{#if isTechnician}}
    <div class="tech-panel">
        <strong>Technician Tools</strong>
        <p class="mb-2 mt-1 small">Click any <span class="badge bg-danger">Reserved</span> slot below to cancel a no-show, or use the form to manually book a walk-in.</p>
        <form action="/tech/reserve" method="POST" class="row g-2 align-items-end mt-1">
            <div class="col-md-3">
                <label class="form-label small fw-bold mb-1">Walk-in Name</label>
                <input type="text" name="walkinName" class="form-control form-control-sm" placeholder="Student name" required>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-bold mb-1">Date</label>
                <input type="date" name="date" class="form-control form-control-sm" required>
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-bold mb-1">Time Slot</label>
                <select name="slotTime" class="form-select form-select-sm" required>
                    <option>7:30 AM - 8:00 AM</option>
                    <option>8:00 AM - 8:30 AM</option>
                    <option>8:30 AM - 9:00 AM</option>
                    <option>9:00 AM - 9:30 AM</option>
                    <option>9:30 AM - 10:00 AM</option>
                    <option>10:00 AM - 10:30 AM</option>
                    <option>10:30 AM - 11:00 AM</option>
                    <option>11:00 AM - 11:30 AM</option>
                    <option>11:30 AM - 12:00 PM</option>
                    <option>12:00 PM - 12:30 PM</option>
                    <option>12:30 PM - 1:00 PM</option>
                    <option>1:00 PM - 1:30 PM</option>
                    <option>1:30 PM - 2:00 PM</option>
                    <option>2:00 PM - 2:30 PM</option>
                    <option>2:30 PM - 3:00 PM</option>
                    <option>3:00 PM - 3:30 PM</option>
                    <option>3:30 PM - 4:00 PM</option>
                    <option>4:00 PM - 4:30 PM</option>
                    <option>4:30 PM - 5:00 PM</option>
                </select>
            </div>
            <input type="hidden" name="room" value="{{labName}}">
            <input type="hidden" name="slotIndex" value="0">
            <div class="col-md-2">
                <button type="submit" class="btn btn-warning btn-sm w-100">Book Walk-in</button>
            </div>
        </form>
    </div>
    {{/if}}

    <div class="table-responsive bg-white shadow-sm rounded">
        <table class="table table-bordered text-center align-middle mb-0">
            <thead class="table-dark sticky-top">
                <tr>
                    <th>Timeslots</th>
                    {{#each days}}<th>{{this}}</th>{{/each}}
                </tr>
            </thead>
            <tbody>
                {{#each timeslots}}
                <tr>
                    <td class="fw-bold small">{{this.timeLabel}}</td>
                    {{#each this.dayCells}}
                    <td>
                        {{#if this.reserved}}
                            {{#if this.isCheckedIn}}
                                <button class="btn btn-sm btn-checkedin w-100" disabled>Checked-in</button>
                            {{else if this.isFaculty}}
                                {{#if ../isTechnician}}
                                {{! Technicians can cancel faculty slots too via no-show form }}
                                <form action="/tech/cancel-noshow" method="POST" class="m-0">
                                    <input type="hidden" name="resId" value="{{this.reservationId}}">
                                    <input type="hidden" name="room"  value="{{../../labName}}">
                                    <input type="hidden" name="date"  value="{{this.isoDate}}">
                                    <button type="submit" class="btn btn-sm btn-faculty w-100"
                                        onclick="return confirm('Cancel this faculty reservation?')">
                                        Faculty
                                    </button>
                                </form>
                                {{else}}
                                <button class="btn btn-sm btn-faculty w-100" disabled>Faculty</button>
                                {{/if}}
                            {{else}}
                                {{#if ../../isTechnician}}
                                <form action="/tech/cancel-noshow" method="POST" class="m-0">
                                    <input type="hidden" name="resId" value="{{this.reservationId}}">
                                    <input type="hidden" name="room"  value="{{../../labName}}">
                                    <input type="hidden" name="date"  value="{{this.isoDate}}">
                                    <button type="submit" class="btn btn-sm btn-reserved w-100"
                                        onclick="return confirm('Cancel this reservation as no-show?')">
                                        No-show?
                                    </button>
                                </form>
                                {{else}}
                                <button class="btn btn-sm btn-reserved w-100" disabled>Reserved</button>
                                {{/if}}
                            {{/if}}
                        {{else}}
                            <button class="btn btn-sm btn-available w-100"
                                data-day="{{this.dayIndex}}"
                                data-slot="{{this.slotIndex}}"
                                data-date="{{this.isoDate}}"
                                data-time="{{../timeLabel}}"
                                onclick="reserveSlot(this, '{{this.isoDate}}', {{this.slotIndex}}, '{{../../labName}}')">
                                Reserve
                            </button>
                        {{/if}}
                    </td>
                    {{/each}}
                </tr>
                {{/each}}
            </tbody>
        </table>
    </div>

    {{! Anonymity modal }}
    <div class="modal fade" id="anonModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg p-3">
                <div class="modal-header border-0">
                    <h5 class="modal-title fw-bold">Reservation Privacy</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                    <div class="modal-body">
                    <p>Would you like to reserve these slots anonymously?</p>
                </div>
                <div class="modal-footer border-0 d-flex gap-2">
                    <button class="btn btn-success flex-grow-1" onclick="processBooking(true)">Yes, Anonymous</button>
                    <button class="btn btn-outline-secondary flex-grow-1" onclick="processBooking(false)">No, Show My Name</button>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3 d-flex justify-content-center gap-3">
        <span><span class="badge btn-available border text-dark">White</span> Available</span>
        <span><span class="badge bg-warning text-dark">Yellow</span> Selected</span>
        <span><span class="badge bg-danger">Red</span> Reserved</span>
        <span><span class="badge bg-primary">Blue</span> Faculty</span>
        <span><span class="badge bg-success">Green</span> Checked-in</span>
        {{#if isTechnician}}<span><span class="badge bg-warning text-dark">Click red/blue</span> Cancel no-show</span>{{/if}}
    </div>
</div>

{{#section "pageScripts"}}
<script src="/js/rooms.js"></script>
{{/section}}

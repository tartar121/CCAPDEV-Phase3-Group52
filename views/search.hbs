<div class="container mt-5" style="max-width: 500px;">
    <div class="card p-4 shadow-sm">
        <h3>Search Lab Availability</h3>
        <form action="/rooms" method="GET">
            <div class="mb-3">
                <label class="form-label fw-bold">Select Lab</label>
                <select name="lab" class="form-select" required>
                    <option>Gokongwei 302</option>
                    <option>Gokongwei 306</option>
                    <option>Velasco 211</option>
                    <option>Andrew 1904</option>
                    <option>Andrew 1401</option>
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Date</label>
                <input type="date" name="date" id="searchDate" class="form-control" required>
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Time (optional)</label>
                <select name="time" class="form-select">
                    <option value="">Any time</option>
                    <option>08:00 AM</option><option>08:30 AM</option>
                    <option>09:00 AM</option><option>09:30 AM</option>
                    <option>10:00 AM</option><option>10:30 AM</option>
                    <option>11:00 AM</option><option>11:30 AM</option>
                    <option>12:00 PM</option><option>12:30 PM</option>
                    <option>01:00 PM</option><option>01:30 PM</option>
                    <option>02:00 PM</option><option>02:30 PM</option>
                    <option>03:00 PM</option><option>03:30 PM</option>
                    <option>04:00 PM</option><option>04:30 PM</option>
                </select>
            </div>
            <button type="submit" class="btn btn-success w-100">Search Availability</button>
        </form>
    </div>
</div>

<script>
    // Restrict date picker to today and 7 days ahead only
    const dateInput = document.getElementById('searchDate')
    const toLocalISO = d => `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`
    const todayLocal = new Date()
    const maxLocal   = new Date(todayLocal)
    maxLocal.setDate(maxLocal.getDate() + 7)
    dateInput.min = toLocalISO(todayLocal)
    dateInput.max = toLocalISO(maxLocal)
    dateInput.value = toLocalISO(todayLocal)
</script>
